# OS noise
.DS_Store

# Secrets & credentials — never commit real values; use *_REF placeholders +
# environment variables / keychain / secret manager (see SECURITY.md).
.env
.env.*
!.env.example
*.credentials
*credentials*.json
*.pem
*.key

# Local-only notes and overrides (per-machine, may hold sensitive context)
*.local.md
.claude/settings.local.json

# Runtime artifacts from verifies / watchdog (may capture app state or PII)
screenshots/
*.png
*.jpg
hang-*.log
watchdog-*.log
heartbeats/

# Scratch / reconciliation temp files
*.tmp
*.reconcile.json
